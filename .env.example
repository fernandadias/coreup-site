# Resend (https://resend.com → Settings → API Keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx

# Email que recebe as notificações de novo lead (geralmente o email da Fernanda)
LEAD_NOTIFY_EMAIL=fernanda.gracas@stone.com.br

# Remetente dos emails. Enquanto não tiver domínio próprio, use "CoreUP <onboarding@resend.dev>".
# Depois de verificar o domínio, trocar para "Fernanda · CoreUP <contato@coreupteam.com.br>"
LEAD_FROM_EMAIL=CoreUP Team <onboarding@resend.dev>

# Google Apps Script Web App (veja docs/apps-script-leads.gs)
SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/xxxxx/exec
SHEETS_WEBHOOK_TOKEN=trocar-por-token-secreto

# WhatsApp (formato internacional, só dígitos, ex: 5511999999999)
NEXT_PUBLIC_WHATSAPP_NUMBER=5511999999999
